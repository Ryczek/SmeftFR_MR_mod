     gc47L -> (10*G1^4*GW^2 + 6*CphiWB*G1^5*GW*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) + 8*CphiWB*G1^3*GW^3*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) + 2*CphiWB*G1*GW^5*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) + G1^6*(2 + CphiWB^2*Lam^2*vev^4) + 3*GW^6*(2 + CphiWB^2*Lam^2*vev^4) + 2*G1^2*GW^4*(7 + 4*CphiWB^2*Lam^2*vev^4))/(12*(G1^2 + GW^2)^(5/2)),
     gc47R -> -1/6*(G1*(2*CphiWB*G1^2*GW^3*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) + 2*CphiWB*GW^5*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) + G1*GW^4*(2 - CphiWB^2*Lam^2*vev^4) + G1^5*(2 + CphiWB^2*Lam^2*vev^4) + G1^3*GW^2*(4 + 3*CphiWB^2*Lam^2*vev^4)))/(G1^2 + GW^2)^(5/2),
     gc48L -> -1/4*((G1^2 - GW^2)*(-2*CphiWB*G1^3*GW*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) - 2*CphiWB*G1*GW^3*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) + G1^4*(2 + CphiWB^2*Lam^2*vev^4) + GW^4*(2 + CphiWB^2*Lam^2*vev^4) + G1^2*GW^2*(4 + 5*CphiWB^2*Lam^2*vev^4)))/(G1^2 + GW^2)^(5/2),
     gc48R -> -1/2*(G1*(2*CphiWB*G1^2*GW^3*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) + 2*CphiWB*GW^5*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) + G1*GW^4*(2 - CphiWB^2*Lam^2*vev^4) + G1^5*(2 + CphiWB^2*Lam^2*vev^4) + G1^3*GW^2*(4 + 3*CphiWB^2*Lam^2*vev^4)))/(G1^2 + GW^2)^(5/2),
     gc49L -> (-6*CphiWB*G1^5*GW*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) - 4*CphiWB*G1^3*GW^3*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) + 2*CphiWB*G1*GW^5*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) - 2*G1^4*GW^2*(1 - 3*CphiWB^2*Lam^2*vev^4) - 10*G1^2*GW^4*(1 + CphiWB^2*Lam^2*vev^4) + G1^6*(2 + CphiWB^2*Lam^2*vev^4) - 3*GW^6*(2 + CphiWB^2*Lam^2*vev^4))/(12*(G1^2 + GW^2)^(5/2)),
     gc49R -> (G1*(2*CphiWB*G1^2*GW^3*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) + 2*CphiWB*GW^5*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) + G1*GW^4*(2 - CphiWB^2*Lam^2*vev^4) + G1^5*(2 + CphiWB^2*Lam^2*vev^4) + G1^3*GW^2*(4 + 3*CphiWB^2*Lam^2*vev^4)))/(3*(G1^2 + GW^2)^(5/2)),
     gc50 -> (-2*CphiWB*G1^3*GW*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) - 2*CphiWB*G1*GW^3*Lam*vev^2*(1 + CphiB*Lam*vev^2 + CphiW*Lam*vev^2) - G1^4*(2 + CphiWB^2*Lam^2*vev^4) - GW^4*(2 + CphiWB^2*Lam^2*vev^4) - G1^2*GW^2*(4 + CphiWB^2*Lam^2*vev^4))/(4*(G1^2 + GW^2)^(3/2))};

