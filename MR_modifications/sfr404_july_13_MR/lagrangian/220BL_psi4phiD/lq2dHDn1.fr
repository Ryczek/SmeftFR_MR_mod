(* SmeftFR v4.0 - class 220 (psi^4 H D) BLV operator: lq2dHDn1 *)
(* WARNING: baryon and lepton number violating! *)

(* Q_lq2dHD^(1) = i eps_{a b c} eps_{jn} eps_{km} (q_p^{m a} C ga^mu d_r^b) (q_s^{j c} C l_t^k) D_mu H^n + h.c. *)
LQlq2dHDn1 := Module[{sp1,sp2,sp3,sp4,sp5,ff1,ff2,ff3,ff4,jj,kk,mm,nn,aa,bb,cc,mu,aux},

aux = Eps[aa,bb,cc] Eps[jj,nn] Eps[kk,mm] Ga[mu,sp2,sp3] DC[Phi8[nn],mu]
  HC[CC[QL8][sp1,mm,ff1,aa]].Ga[0,sp1,sp2].dR8[sp3,ff2,bb]
  HC[CC[QL8][sp4,jj,ff3,cc]].Ga[0,sp4,sp5].LL8[sp5,kk,ff4];

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "lq2dHDn1"][ff1,ff2,ff3,ff4] aux,
      FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
