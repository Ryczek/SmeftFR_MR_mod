(* SmeftFR v4.0 - class 218 (psi^4 H^2) operator: l2udphi2 *)

(* Q_l2udphi2 = (lbar_p d_r H)(Htilde^dag ubar_s l_t) + h.c. *)
LQl2udphi2 := Module[{sp1,sp2,ff1,ff2,ff3,ff4,cc,ii,jj,kk,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "l2udphi2"][ff1,ff2,ff3,ff4]
  (LL8bar[sp1,ii,ff1].dR8[sp1,ff2,cc]).(uR8bar[sp2,ff3,cc].LL8[sp2,jj,ff4])
  Phi8[ii] Eps[jj,kk] Phi8[kk],
  FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
