(* SmeftFR v4.0 - class 218 (psi^4 H^2) operator: q2d2phi2n6 *)

(* Q_q2d2phi2^(6) = (qbar_p T^A d_r H)(qbar_s T^A d_t H) + h.c. *)
LQq2d2phi2n6 := Module[{sp1,sp2,ff1,ff2,ff3,ff4,aa,cc1,cc2,dd1,dd2,ii,jj,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "q2d2phi2n6"][ff1,ff2,ff3,ff4]
  (QL8bar[sp1,ii,ff1,cc1].dR8[sp1,ff2,dd1]).(QL8bar[sp2,jj,ff3,cc2].dR8[sp2,ff4,dd2])
  T8[aa,cc1,dd1] T8[aa,cc2,dd2]
  Phi8[ii] Phi8[jj],
  FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
