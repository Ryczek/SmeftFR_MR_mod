(* SmeftFR v4.0 - class 218 (psi^4 H^2) operator: q2u2phi2n5 *)

(* Q_q2u2phi2^(5) = (qbar_p u_r Htilde)(qbar_s u_t Htilde) + h.c. *)
LQq2u2phi2n5 := Module[{sp1,sp2,ff1,ff2,ff3,ff4,cc1,cc2,ii,jj,kk,mm,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "q2u2phi2n5"][ff1,ff2,ff3,ff4]
  (QL8bar[sp1,ii,ff1,cc1].uR8[sp1,ff2,cc1]).(QL8bar[sp2,jj,ff3,cc2].uR8[sp2,ff4,cc2])
  Eps[ii,kk] HC[Phi8[kk]] Eps[jj,mm] HC[Phi8[mm]],
  FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
