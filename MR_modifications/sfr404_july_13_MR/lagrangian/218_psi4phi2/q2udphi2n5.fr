(* SmeftFR v4.0 - class 218 (psi^4 H^2) operator: q2udphi2n5 *)

(* Q_q2udphi2^(5) = (qbar_p d_r H)(Htilde^dag ubar_s q_t) + h.c. *)
LQq2udphi2n5 := Module[{sp1,sp2,ff1,ff2,ff3,ff4,cc1,cc2,ii,jj,kk,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "q2udphi2n5"][ff1,ff2,ff3,ff4]
  (QL8bar[sp1,ii,ff1,cc1].dR8[sp1,ff2,cc1]).(uR8bar[sp2,ff3,cc2].QL8[sp2,jj,ff4,cc2])
  Phi8[ii] Eps[jj,kk] Phi8[kk],
  FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
