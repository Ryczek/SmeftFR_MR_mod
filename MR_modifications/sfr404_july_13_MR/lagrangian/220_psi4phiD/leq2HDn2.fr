(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: leq2HDn2 *)

(* Q_leq2HD^(2) = i (lbar_p ga^mu q_r^al) [(qbar_{s al} e_t) D_mu H] + h.c. *)
LQleq2HDn2 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,ii,jj,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "leq2HDn2"][ff1,ff2,ff3,ff4]
  (LL8bar[sp1,ii,ff1].QL8[sp2,ii,ff2,co1]).(QL8bar[sp3,jj,ff3,co1].lR8[sp3,ff4])
  Ga[mu,sp1,sp2] DC[Phi8[jj],mu],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
