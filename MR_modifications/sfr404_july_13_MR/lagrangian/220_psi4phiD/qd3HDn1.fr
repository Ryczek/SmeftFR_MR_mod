(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: qd3HDn1 *)

(* Q_qd3HD^(1) = i (dbar_p ga^mu d_r) [(qbar_s d_t) D_mu H] + h.c. *)
LQqd3HDn1 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,co2,jj,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "qd3HDn1"][ff1,ff2,ff3,ff4]
  (dR8bar[sp1,ff1,co1].dR8[sp2,ff2,co1]).(QL8bar[sp3,jj,ff3,co2].dR8[sp3,ff4,co2])
  Ga[mu,sp1,sp2] DC[Phi8[jj],mu],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
