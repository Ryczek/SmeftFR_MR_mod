aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "led2HDn3"][ff1,ff2,ff3,ff4]
  (dR8bar[sp1,ff1,co1].dR8[sp2,ff2,co1]).(DC[LL8bar[sp3,jj,ff3],mu].lR8[sp3,ff4])
  Ga[mu,sp1,sp2] Phi8[jj],
