(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: leu2HDn3 *)

(* Q_leu2HD^(3) = i (ubar_p ga^mu u_r) [(D_mu lbar_s e_t) H] + h.c. *)
LQleu2HDn3 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,jj,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "leu2HDn3"][ff1,ff2,ff3,ff4]
  (uR8bar[sp1,ff1,co1].uR8[sp2,ff2,co1]).(DC[LL8bar[sp3,jj,ff3],mu].lR8[sp3,ff4])
  Ga[mu,sp1,sp2] Phi8[jj],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
