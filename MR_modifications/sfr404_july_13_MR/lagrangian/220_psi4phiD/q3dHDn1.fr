(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: q3dHDn1 *)

(* Q_q3dHD^(1) = i (qbar_p ga^mu q_r) [(qbar_s d_t) D_mu H] + h.c. *)
LQq3dHDn1 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,co2,ii,jj,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "q3dHDn1"][ff1,ff2,ff3,ff4]
  (QL8bar[sp1,ii,ff1,co1].QL8[sp2,ii,ff2,co1]).(QL8bar[sp3,jj,ff3,co2].dR8[sp3,ff4,co2])
  Ga[mu,sp1,sp2] DC[Phi8[jj],mu],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
