(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: l3eHDn1 *)

(* Q_l3eHD^(1) = i (lbar_p gamma^mu l_r) [(lbar_s e_t) D_mu H] + h.c. *)
LQl3eHDn1 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,ii,jj,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "l3eHDn1"][ff1,ff2,ff3,ff4]
  (LL8bar[sp1,ii,ff1].LL8[sp2,ii,ff2]).(LL8bar[sp3,jj,ff3].lR8[sp3,ff4])
  Ga[mu,sp1,sp2] DC[Phi8[jj],mu],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
