(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: e2quHDn3 *)

(* Q_e2quHD^(3) = i (ebar_p ga^mu e_r) [(D_mu qbar_s u_t) Htilde] + h.c. *)
LQe2quHDn3 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,jj,kk,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "e2quHDn3"][ff1,ff2,ff3,ff4]
  (lR8bar[sp1,ff1].lR8[sp2,ff2]).(DC[QL8bar[sp3,jj,ff3,co1],mu].uR8[sp3,ff4,co1])
  Ga[mu,sp1,sp2] Eps[jj,kk] HC[Phi8[kk]],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
