(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: e2qdHDn3 *)

(* Q_e2qdHD^(3) = i (ebar_p ga^mu e_r) [(D_mu qbar_s d_t) H] + h.c. *)
LQe2qdHDn3 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,jj,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "e2qdHDn3"][ff1,ff2,ff3,ff4]
  (lR8bar[sp1,ff1].lR8[sp2,ff2]).(DC[QL8bar[sp3,jj,ff3,co1],mu].dR8[sp3,ff4,co1])
  Ga[mu,sp1,sp2] Phi8[jj],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
