(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: qud2HDn2 *)

(* Q_qud2HD^(2) = i (dbar_p ga^mu u_r) [(qbar_s d_t) D_mu Htilde] + h.c. *)
LQqud2HDn2 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,co2,jj,kk,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "qud2HDn2"][ff1,ff2,ff3,ff4]
  (dR8bar[sp1,ff1,co1].uR8[sp2,ff2,co1]).(QL8bar[sp3,jj,ff3,co2].dR8[sp3,ff4,co2])
  Ga[mu,sp1,sp2] Eps[jj,kk] DC[Phi8bar[kk],mu],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
