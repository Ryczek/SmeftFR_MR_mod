(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: leudHDn2 *)

(* Q_leudHD^(2) = i eps_{jk} (ebar_p ga^mu d_r^al) (ubar_{s al} l_t^j) D_mu H^k + h.c. *)
LQleudHDn2 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,jj,kk,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "leudHDn2"][ff1,ff2,ff3,ff4]
  (lR8bar[sp1,ff1].dR8[sp2,ff2,co1]).(uR8bar[sp3,ff3,co1].LL8[sp3,jj,ff4])
  Ga[mu,sp1,sp2] Eps[jj,kk] DC[Phi8[kk],mu],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
