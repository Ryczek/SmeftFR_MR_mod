(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: le3HDn2 *)

(* Q_le3HD^(2) = i (ebar_p ga^mu e_r) [(lbar_s e_t) D_mu H] + h.c. *)
LQle3HDn2 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,jj,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "le3HDn2"][ff1,ff2,ff3,ff4]
  (lR8bar[sp1,ff1].lR8[sp2,ff2]).(LL8bar[sp3,jj,ff3].lR8[sp3,ff4])
  Ga[mu,sp1,sp2] DC[Phi8[jj],mu],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
