(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: l2quHDn5 *)

(* Q_l2quHD^(5) = i (lbar_p ga^mu l_r) [(qbar_s D_mu u_t) Htilde] + h.c. *)
LQl2quHDn5 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,ii,jj,kk,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "l2quHDn5"][ff1,ff2,ff3,ff4]
  (LL8bar[sp1,ii,ff1].LL8[sp2,ii,ff2]).(QL8bar[sp3,jj,ff3,co1].DC[uR8[sp3,ff4,co1],mu])
  Ga[mu,sp1,sp2] Eps[jj,kk] HC[Phi8[kk]],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
