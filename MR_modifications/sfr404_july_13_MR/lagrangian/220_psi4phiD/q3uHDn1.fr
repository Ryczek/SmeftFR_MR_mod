(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: q3uHDn1 *)

(* Q_q3uHD^(1) = i (qbar_p ga^mu q_r) [(qbar_s u_t) D_mu Htilde] + h.c. *)
LQq3uHDn1 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,co2,ii,jj,kk,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "q3uHDn1"][ff1,ff2,ff3,ff4]
  (QL8bar[sp1,ii,ff1,co1].QL8[sp2,ii,ff2,co1]).(QL8bar[sp3,jj,ff3,co2].uR8[sp3,ff4,co2])
  Ga[mu,sp1,sp2] Eps[jj,kk] DC[Phi8bar[kk],mu],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
