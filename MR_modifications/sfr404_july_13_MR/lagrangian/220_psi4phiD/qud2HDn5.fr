(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: qud2HDn5 *)

(* Q_qud2HD^(5) = i (dbar_p ga^mu d_r) [(D_mu qbar_s u_t) Htilde] + h.c. *)
LQqud2HDn5 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,co2,jj,kk,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "qud2HDn5"][ff1,ff2,ff3,ff4]
  (dR8bar[sp1,ff1,co1].dR8[sp2,ff2,co1]).(DC[QL8bar[sp3,jj,ff3,co2],mu].uR8[sp3,ff4,co2])
  Ga[mu,sp1,sp2] Eps[jj,kk] HC[Phi8[kk]],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
