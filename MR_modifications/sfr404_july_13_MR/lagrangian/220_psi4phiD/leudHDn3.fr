(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: leudHDn3 *)

(* Q_leudHD^(3) = i eps_{jk} (ubar_p ga^mu d_r) (ebar_s D_mu l_t^j) H^k + h.c. *)
LQleudHDn3 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,jj,kk,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "leudHDn3"][ff1,ff2,ff3,ff4]
  (uR8bar[sp1,ff1,co1].dR8[sp2,ff2,co1]).(lR8bar[sp3,ff3].DC[LL8[sp3,jj,ff4],mu])
  Ga[mu,sp1,sp2] Eps[jj,kk] Phi8[kk],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
