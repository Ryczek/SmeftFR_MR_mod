(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: l2quHDn2 *)

(* Q_l2quHD^(2) = i (qbar_{p al} ga^mu l_r) [(lbar_s u_t^al) D_mu Htilde] + h.c. *)
LQl2quHDn2 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,ii,jj,kk,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "l2quHDn2"][ff1,ff2,ff3,ff4]
  (QL8bar[sp1,ii,ff1,co1].LL8[sp2,ii,ff2]).(LL8bar[sp3,jj,ff3].uR8[sp3,ff4,co1])
  Ga[mu,sp1,sp2] Eps[jj,kk] DC[Phi8bar[kk],mu],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
