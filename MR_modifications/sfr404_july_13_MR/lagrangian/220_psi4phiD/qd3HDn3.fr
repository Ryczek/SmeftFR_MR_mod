(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: qd3HDn3 *)

(* Q_qd3HD^(3) = i (dbar_p ga^mu d_r) [(qbar_s D_mu d_t) H] + h.c. *)
LQqd3HDn3 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,co2,jj,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "qd3HDn3"][ff1,ff2,ff3,ff4]
  (dR8bar[sp1,ff1,co1].dR8[sp2,ff2,co1]).(QL8bar[sp3,jj,ff3,co2].DC[dR8[sp3,ff4,co2],mu])
  Ga[mu,sp1,sp2] Phi8[jj],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
