(* SmeftFR v4.0 - class 220 (psi^4 H D) operator: leu2HDn2 *)

(* Q_leu2HD^(2) = i (ubar_{p al} ga^mu e_r) [(lbar_s u_t^al) D_mu H] + h.c. *)
LQleu2HDn2 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,co1,jj,mu,aux},

aux = I ExpandIndices[ ToExpression[SMEFT$WB <> "leu2HDn2"][ff1,ff2,ff3,ff4]
  (uR8bar[sp1,ff1,co1].lR8[sp2,ff2]).(LL8bar[sp3,jj,ff3].uR8[sp3,ff4,co1])
  Ga[mu,sp1,sp2] DC[Phi8[jj],mu],
  FlavorExpand->{SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
