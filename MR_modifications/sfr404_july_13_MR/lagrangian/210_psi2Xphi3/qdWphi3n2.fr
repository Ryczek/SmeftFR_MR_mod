(* SmeftFR v4.0 - class 210 (psi^2 X H^3) operator: qdWphi3n2 *)

(* Q_qdWphi3^(2) = (qbar_p sigma^{mu nu} d_r) H (H^dag tau^I H) W^I_{mu nu} + h.c. *)
LQqdWphi3n2 := Module[{sp1,sp2,ii,ll,mm,nn,cc,mu,nu,ff1,ff2,aux},

aux = QL8bar[sp1,ii,ff1,cc].dR8[sp2,ff2,cc] Sigma[mu,nu,sp1,sp2] Phi8[ii]
  Phi8bar[mm] 2 Ta8[ll,mm,nn] Phi8[nn] FS[Wi8,mu,nu,ll];

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "qdWphi3n2"][ff1,ff2] aux,
  FlavorExpand -> {SU2W8,SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
