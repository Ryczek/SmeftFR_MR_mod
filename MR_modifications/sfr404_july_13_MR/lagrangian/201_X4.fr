aux = (FS[Gl8,mu,nu,aa] Eps[mu,nu,al,be]/2 HC[FS[Gl8,al,be,aa]]) (FS[Gl8,ro,si,bb] Eps[ro,si,ga,de]/2 HC[FS[Gl8,ga,de,bb]]);

