LQG4n1 := Module[{aa,bb,mu,nu,ro,si,aux},

aux = (FS[Gl8,mu,nu,aa] FS[Gl8,mu,nu,aa]) (FS[Gl8,ro,si,bb] FS[Gl8,ro,si,bb]);

ExpandIndices[ ToExpression[SMEFT$WB <> "G4n1"] aux ] /. SMEFTGaugeRules
];



