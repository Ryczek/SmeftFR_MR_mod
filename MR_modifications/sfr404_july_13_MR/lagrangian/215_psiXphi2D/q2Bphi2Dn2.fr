(* SmeftFR v4.0 - class 215 (psi^2 X H^2 D) operator: q2Bphi2Dn2 *)

(* Q_q2BH2D^(2) = (qbar_p ga^nu tau^I q_r) D^mu (H^dag tau H) Btilde_{mu nu} *)
LQq2Bphi2Dn2 := Module[{sp1,sp2,ii,jj,kk,oo,co,ll,mu,nu,al,be,ff1,ff2,aux},

aux = QL8bar[sp1,ii,ff1,co].QL8[sp2,jj,ff2,co] Ga[nu,sp1,sp2] 2 Ta8[ll,ii,jj]
      (DC[Phi8bar[kk],mu] 2 Ta8[ll,kk,oo] Phi8[oo] +
       Phi8bar[kk] 2 Ta8[ll,kk,oo] DC[Phi8[oo],mu])
      Eps[mu,nu,al,be]/2 HC[FS[B8,al,be]];

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "q2Bphi2Dn2"][ff1,ff2] aux,
      FlavorExpand->{SU2D8} ];
aux = ExpandIndices[ aux, FlavorExpand->{SU2W8} ];

aux /. SMEFTGaugeRules
];
