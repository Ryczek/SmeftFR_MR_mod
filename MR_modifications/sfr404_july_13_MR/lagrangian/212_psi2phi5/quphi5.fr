(* SmeftFR v4.0 package *)
(* dim-8 operators from 2005.00059 - psi^2H^5 class*)

(* Operators implemented: quphi5 *)

LQquphi5 := Module[{sp,ii,jj,kk,ff1,ff2,cc,aux,tmp},

tmp = ExpandIndices[Phi8bar[jj] Phi8[jj], FlavorExpand -> {SU2D8} ];

aux = tmp^2 ExpandIndices[ ToExpression[SMEFT$WB <> "quphi5"][ff1,ff2]
  QL8bar[sp,ii,ff1,cc].uR8[sp,ff2,cc] Eps[ii,kk] HC[Phi8[kk]],
  FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
