(* SmeftFR v4.0 package *)
(* dim-8 operators from 2005.00059 - psi^2H^5 class*)

(* Operators implemented: lephi5 *)

LQlephi5 := Module[{sp,ii,jj,ff1,ff2,aux,tmp},
		
tmp = ExpandIndices[Phi8bar[jj] Phi8[jj], FlavorExpand -> {SU2D8} ];

aux = tmp^2 ExpandIndices[ ToExpression[SMEFT$WB <> "lephi5"][ff1,ff2]
  LL8bar[sp,ii,ff1].lR8[sp,ff2] Phi8[ii], FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
