(* SmeftFR v4.0 - class 211 (psi^2 H^2 D^3) operator: d2phi2D3n1 *)

(* Q_d2phi2D3^(1) = i (dbar_p ga^mu D^nu d_r) (D_(mu D_nu) H^dag H) *)
LQd2phi2D3n1 := Module[ {sp1,sp2,jj,cc,mu,nu,ff1,ff2,aux,tmp1,tmp2},

tmp1 = dR8bar[sp1,ff1,cc].DC[dR8[sp2,ff2,cc],nu];

tmp2 = ExpandIndices[ (DC[DC[Phi8bar[jj],mu],nu] + DC[DC[Phi8bar[jj],nu],mu]) Phi8[jj], FlavorExpand -> {SU2D8} ];

aux = I/2 ExpandIndices[ ToExpression[SMEFT$WB <> "d2phi2D3n1"][ff1,ff2]
  tmp1 Ga[mu,sp1,sp2] tmp2, FlavorExpand->{SU2W8} ];

aux /. SMEFTGaugeRules
];
