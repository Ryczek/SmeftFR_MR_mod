(* SmeftFR v4.0 - class 219 (psi^4 X) operator: u4Bn1 *)

(* Q_u4B^(1) = (ubar_p ga^mu u_r)(ubar_s ga^nu u_t) B_{mu nu} *)
LQu4Bn1 := Module[{sp1,sp2,sp3,sp4,ff1,ff2,ff3,ff4,co1,co3,mu,nu,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "u4Bn1"][ff1,ff2,ff3,ff4]
  (uR8bar[sp1,ff1,co1].uR8[sp2,ff2,co1]).(uR8bar[sp3,ff3,co3].uR8[sp4,ff4,co3])
  Ga[mu,sp1,sp2] Ga[nu,sp3,sp4]
  FS[B8,mu,nu],
  FlavorExpand->{SU2D8} ];

aux /. SMEFTGaugeRules
];
