(* SmeftFR v4.0 - class 219 (psi^4 X) operator: e2d2Bn1 *)

(* Q_e2d2B^(1) = (ebar_p ga^mu e_r)(dbar_s ga^nu d_t) B_{mu nu} *)
LQe2d2Bn1 := Module[{sp1,sp2,sp3,sp4,ff1,ff2,ff3,ff4,co3,mu,nu,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "e2d2Bn1"][ff1,ff2,ff3,ff4]
  (lR8bar[sp1,ff1].lR8[sp2,ff2]).(dR8bar[sp3,ff3,co3].dR8[sp4,ff4,co3])
  Ga[mu,sp1,sp2] Ga[nu,sp3,sp4]
  FS[B8,mu,nu],
  FlavorExpand->{SU2D8} ];

aux /. SMEFTGaugeRules
];
