(* SmeftFR v4.0 - class 219 (psi^4 X) operator: l2q2Bn2 *)

(* Q_l2q2B^(2) = (lbar_p ga^mu l_r)(qbar_s ga^nu q_t) Btilde_{mu nu} *)
LQl2q2Bn2 := Module[{sp1,sp2,sp3,sp4,ff1,ff2,ff3,ff4,co3,ii,kk,mu,nu,al,be,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "l2q2Bn2"][ff1,ff2,ff3,ff4]
  (LL8bar[sp1,ii,ff1].LL8[sp2,ii,ff2]).(QL8bar[sp3,kk,ff3,co3].QL8[sp4,kk,ff4,co3])
  Ga[mu,sp1,sp2] Ga[nu,sp3,sp4]
  Eps[mu,nu,al,be]/2 HC[FS[B8,al,be]],
  FlavorExpand->{SU2D8} ];

aux /. SMEFTGaugeRules
];
