(* SmeftFR v4.0 - class 219 (psi^4 X) operator: d4Bn2 *)

(* Q_d4B^(2) = (dbar_p ga^mu d_r)(dbar_s ga^nu d_t) Btilde_{mu nu} *)
LQd4Bn2 := Module[{sp1,sp2,sp3,sp4,ff1,ff2,ff3,ff4,co1,co3,mu,nu,al,be,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "d4Bn2"][ff1,ff2,ff3,ff4]
  (dR8bar[sp1,ff1,co1].dR8[sp2,ff2,co1]).(dR8bar[sp3,ff3,co3].dR8[sp4,ff4,co3])
  Ga[mu,sp1,sp2] Ga[nu,sp3,sp4]
  Eps[mu,nu,al,be]/2 HC[FS[B8,al,be]],
  FlavorExpand->{SU2D8} ];

aux /. SMEFTGaugeRules
];
