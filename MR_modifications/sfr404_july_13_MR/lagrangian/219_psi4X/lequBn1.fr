(* SmeftFR v4.0 - class 219 (psi^4 X) operator: lequBn1 *)

(* Q_lequB^(1) = (lbar_p^j sigma^{mu nu} e_r) eps_{jk} (qbar_s^k u_t) B_{mu nu} + h.c. *)
LQlequBn1 := Module[{sp1,sp2,sp3,ff1,ff2,ff3,ff4,cc,jj,kk,mu,nu,aux},

aux = Sigma[mu,nu,sp1,sp2] Eps[jj,kk] FS[B8,mu,nu]
  (LL8bar[sp1,jj,ff1].lR8[sp2,ff2]).(QL8bar[sp3,kk,ff3,cc].uR8[sp3,ff4,cc]);

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "lequBn1"][ff1,ff2,ff3,ff4] aux,
      FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
