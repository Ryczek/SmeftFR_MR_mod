(* SmeftFR v4.0 - class 219 (psi^4 X) operator: l2e2Bn1 *)

(* Q_l2e2B^(1) = (lbar_p ga^mu l_r)(ebar_s ga^nu e_t) B_{mu nu} *)
LQl2e2Bn1 := Module[{sp1,sp2,sp3,sp4,ff1,ff2,ff3,ff4,ii,mu,nu,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "l2e2Bn1"][ff1,ff2,ff3,ff4]
  (LL8bar[sp1,ii,ff1].LL8[sp2,ii,ff2]).(lR8bar[sp3,ff3].lR8[sp4,ff4])
  Ga[mu,sp1,sp2] Ga[nu,sp3,sp4]
  FS[B8,mu,nu],
  FlavorExpand->{SU2D8} ];

aux /. SMEFTGaugeRules
];
