(* SmeftFR v4.0 - class 219 (psi^4 X) operator: l2d2Gn1 *)

(* Q_l2d2G^(1) = (lbar_p ga^mu l_r)(dbar_s ga^nu T^A d_t) G^A_{mu nu} *)
LQl2d2Gn1 := Module[{sp1,sp2,sp3,sp4,ff1,ff2,ff3,ff4,co3,co4,ii,aa,mu,nu,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "l2d2Gn1"][ff1,ff2,ff3,ff4]
  (LL8bar[sp1,ii,ff1].LL8[sp2,ii,ff2]).(dR8bar[sp3,ff3,co3].dR8[sp4,ff4,co4])
  Ga[mu,sp1,sp2] Ga[nu,sp3,sp4] T8[aa,co3,co4]
  FS[Gl8,mu,nu,aa],
  FlavorExpand->{SU2D8} ];

aux /. SMEFTGaugeRules
];
