(* SmeftFR v4.0 - class 219 (psi^4 X) operator: u2d2Bn2 *)

(* Q_u2d2B^(2) = (ubar_p ga^mu u_r)(dbar_s ga^nu d_t) Btilde_{mu nu} *)
LQu2d2Bn2 := Module[{sp1,sp2,sp3,sp4,ff1,ff2,ff3,ff4,co1,co3,mu,nu,al,be,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "u2d2Bn2"][ff1,ff2,ff3,ff4]
  (uR8bar[sp1,ff1,co1].uR8[sp2,ff2,co1]).(dR8bar[sp3,ff3,co3].dR8[sp4,ff4,co3])
  Ga[mu,sp1,sp2] Ga[nu,sp3,sp4]
  Eps[mu,nu,al,be]/2 HC[FS[B8,al,be]],
  FlavorExpand->{SU2D8} ];

aux /. SMEFTGaugeRules
];
