(* SmeftFR v4.0 - class 221 (psi^4 D^2) operator: e2d2D2n2 *)

(* Q_e2d2D2^(2) = (ebar_p ga^mu <->D^nu e_r)(dbar_s ga_mu <->D_nu d_t) *)
LQe2d2D2n2 := Module[{sp1,sp2,sp3,sp4,ff1,ff2,ff3,ff4,co3,mu,nu,tmp1,tmp2,aux},

tmp1 = lR8bar[sp1,ff1].DC[lR8[sp2,ff2],nu] -
  DC[lR8bar[sp1,ff1],nu].lR8[sp2,ff2];

tmp2 = dR8bar[sp3,ff3,co3].DC[dR8[sp4,ff4,co3],nu] -
  DC[dR8bar[sp3,ff3,co3],nu].dR8[sp4,ff4,co3];

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "e2d2D2n2"][ff1,ff2,ff3,ff4]
  tmp1 tmp2 Ga[mu,sp1,sp2] Ga[mu,sp3,sp4],
  FlavorExpand->{SU2W8,SU2D8} ];

aux /. SMEFTGaugeRules
];
