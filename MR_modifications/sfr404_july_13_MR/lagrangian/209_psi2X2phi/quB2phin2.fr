(* SmeftFR v4.0 - class 209 (psi^2 X^2 H) operator: quB2phin2 *)

(* Q_quB2phi^(2) = (qbar_p u_r) Htilde Btilde_{mu nu} B^{mu nu} + h.c. *)
LQquB2phin2 := Module[{sp,ii,kk,cc,mu,nu,al,be,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "quB2phin2"][ff1,ff2]
  QL8bar[sp,ii,ff1,cc].uR8[sp,ff2,cc] Eps[ii,kk] HC[Phi8[kk]]
  Eps[mu,nu,al,be]/2 HC[FS[B8,al,be]] FS[B8,mu,nu], FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
