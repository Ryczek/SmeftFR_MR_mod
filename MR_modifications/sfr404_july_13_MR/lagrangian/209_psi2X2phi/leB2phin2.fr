(* SmeftFR v4.0 - class 209 (psi^2 X^2 H) operator: leB2phin2 *)

(* Q_leB2phi^(2) = (lbar_p e_r) H Btilde_{mu nu} B^{mu nu} + h.c. *)
LQleB2phin2 := Module[{sp,ii,mu,nu,al,be,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "leB2phin2"][ff1,ff2]
  LL8bar[sp,ii,ff1].lR8[sp,ff2] Phi8[ii] Eps[mu,nu,al,be]/2
  HC[FS[B8,al,be]] FS[B8,mu,nu], FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
