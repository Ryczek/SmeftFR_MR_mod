(* SmeftFR v4.0 - class 209 (psi^2 X^2 H) operator: leG2phin2 *)

(* Q_leG2phi^(2) = (lbar_p e_r) H Gtilde^A_{mu nu} G^{A mu nu} + h.c. *)
LQleG2phin2 := Module[{sp,ii,mu,nu,al,be,aa,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "leG2phin2"][ff1,ff2]
  LL8bar[sp,ii,ff1].lR8[sp,ff2] Phi8[ii] Eps[mu,nu,al,be]/2
  HC[FS[Gl8,al,be,aa]] FS[Gl8,mu,nu,aa], FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
