(* SmeftFR v4.0 - class 209 (psi^2 X^2 H) operator: quGBphin1 *)

(* Q_quGBphi^(1) = (qbar_p T^A u_r) Htilde G^A_{mu nu} B^{mu nu} + h.c. *)
LQquGBphin1 := Module[{sp,ii,kk,mm,nn,aa,mu,nu,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "quGBphin1"][ff1,ff2]
  QL8bar[sp,ii,ff1,mm].uR8[sp,ff2,nn] T8[aa,mm,nn] Eps[ii,kk] HC[Phi8[kk]]
  FS[Gl8,mu,nu,aa] FS[B8,mu,nu], FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
