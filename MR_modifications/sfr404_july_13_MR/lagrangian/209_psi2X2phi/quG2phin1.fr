(* SmeftFR v4.0 - class 209 (psi^2 X^2 H) operator: quG2phin1 *)

(* Q_quG2phi^(1) = (qbar_p u_r) Htilde G^A_{mu nu} G^{A mu nu} + h.c. *)
LQquG2phin1 := Module[{sp,ii,kk,cc,mu,nu,aa,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "quG2phin1"][ff1,ff2]
  QL8bar[sp,ii,ff1,cc].uR8[sp,ff2,cc] Eps[ii,kk] HC[Phi8[kk]]
  FS[Gl8,mu,nu,aa] FS[Gl8,mu,nu,aa], FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
