(* SmeftFR v4.0 - class 209 (psi^2 X^2 H) operator: quG2phin3 *)

(* Q_quG2phi^(3) = d^{ABC} (qbar_p T^A u_r) Htilde G^B_{mu nu} G^{C mu nu} + h.c. *)
LQquG2phin3 := Module[{sp,ii,kk,mm,nn,aa,bb,cc,mu,nu,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "quG2phin3"][ff1,ff2]
  dSUN[aa,bb,cc] QL8bar[sp,ii,ff1,mm].uR8[sp,ff2,nn] T8[aa,mm,nn]
  Eps[ii,kk] HC[Phi8[kk]] FS[Gl8,mu,nu,bb] FS[Gl8,mu,nu,cc],
  FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
