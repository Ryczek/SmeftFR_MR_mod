(* SmeftFR v4.0 - class 209 (psi^2 X^2 H) operator: qdB2phin2 *)

(* Q_qdB2phi^(2) = (qbar_p d_r) H Btilde_{mu nu} B^{mu nu} + h.c. *)
LQqdB2phin2 := Module[{sp,ii,cc,mu,nu,al,be,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "qdB2phin2"][ff1,ff2]
  QL8bar[sp,ii,ff1,cc].dR8[sp,ff2,cc] Phi8[ii] Eps[mu,nu,al,be]/2
  HC[FS[B8,al,be]] FS[B8,mu,nu], FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
