(* SmeftFR v4.0 - class 209 (psi^2 X^2 H) operator: qdW2phin1 *)

(* Q_qdW2phi^(1) = (qbar_p d_r) H W^I_{mu nu} W^{I mu nu} + h.c. *)
LQqdW2phin1 := Module[{sp,ii,cc,ll,mu,nu,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "qdW2phin1"][ff1,ff2]
  QL8bar[sp,ii,ff1,cc].dR8[sp,ff2,cc] Phi8[ii] FS[Wi8,mu,nu,ll]
  FS[Wi8,mu,nu,ll], FlavorExpand -> {SU2D8} ];

aux = ExpandIndices[aux, FlavorExpand -> {SU2W8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
