(* SmeftFR v4.0 - class 209 (psi^2 X^2 H) operator: quB2phin1 *)

(* Q_quB2phi^(1) = (qbar_p u_r) Htilde B_{mu nu} B^{mu nu} + h.c. *)
LQquB2phin1 := Module[{sp,ii,kk,cc,mu,nu,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "quB2phin1"][ff1,ff2]
  QL8bar[sp,ii,ff1,cc].uR8[sp,ff2,cc] Eps[ii,kk] HC[Phi8[kk]]
  FS[B8,mu,nu] FS[B8,mu,nu], FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
