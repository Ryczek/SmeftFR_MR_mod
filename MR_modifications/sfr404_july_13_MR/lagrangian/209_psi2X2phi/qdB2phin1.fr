(* SmeftFR v4.0 - class 209 (psi^2 X^2 H) operator: qdB2phin1 *)

(* Q_qdB2phi^(1) = (qbar_p d_r) H B_{mu nu} B^{mu nu} + h.c. *)
LQqdB2phin1 := Module[{sp,ii,cc,mu,nu,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "qdB2phin1"][ff1,ff2]
  QL8bar[sp,ii,ff1,cc].dR8[sp,ff2,cc] Phi8[ii] FS[B8,mu,nu] FS[B8,mu,nu],
  FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
