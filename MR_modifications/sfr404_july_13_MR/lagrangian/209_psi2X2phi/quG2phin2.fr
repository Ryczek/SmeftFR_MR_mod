(* SmeftFR v4.0 - class 209 (psi^2 X^2 H) operator: quG2phin2 *)

(* Q_quG2phi^(2) = (qbar_p u_r) Htilde Gtilde^A_{mu nu} G^{A mu nu} + h.c. *)
LQquG2phin2 := Module[{sp,ii,kk,cc,mu,nu,al,be,aa,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "quG2phin2"][ff1,ff2]
  QL8bar[sp,ii,ff1,cc].uR8[sp,ff2,cc] Eps[ii,kk] HC[Phi8[kk]]
  Eps[mu,nu,al,be]/2 HC[FS[Gl8,al,be,aa]] FS[Gl8,mu,nu,aa],
  FlavorExpand->{SU2D8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
