(* SmeftFR v4.0 - class 216 (psi^2 X H D^2) operator: qdBHD2n2 *)

(* Q_qdBHD2^(2) = (qbar_p D^rho d_r) (D^nu H) Btilde_{rho nu} + h.c. *)
LQqdBHD2n2 := Module[{sp,ii,co,nu,si,al,be,ff1,ff2,aux,tmp},

tmp = ExpandIndices[ QL8bar[sp,ii,ff1,co].DC[dR8[sp,ff2,co],si]
  DC[Phi8[ii],nu]
  Eps[si,nu,al,be]/2 HC[FS[B8,al,be]],
  FlavorExpand->{SU2D8} ];

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "qdBHD2n2"][ff1,ff2] tmp,
  FlavorExpand->{SU2W8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
