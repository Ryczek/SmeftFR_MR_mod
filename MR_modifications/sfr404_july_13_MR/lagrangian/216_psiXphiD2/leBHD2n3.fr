(* SmeftFR v4.0 - class 216 (psi^2 X H D^2) operator: leBHD2n3 *)

(* Q_leBHD2^(3) = (lbar_p sigma^{mu nu} e_r) (D^rho H) (D_rho B_{mu nu}) + h.c. *)
LQleBHD2n3 := Module[{sp1,sp2,ii,mu,nu,si,ff1,ff2,aux,tmp},

tmp = ExpandIndices[ LL8bar[sp1,ii,ff1].lR8[sp2,ff2]
  Sigma[mu,nu,sp1,sp2] DC[Phi8[ii],si] DC[FS[B8,mu,nu],si],
  FlavorExpand->{SU2D8} ];

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "leBHD2n3"][ff1,ff2] tmp,
  FlavorExpand->{SU2W8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
