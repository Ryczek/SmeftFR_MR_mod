(* SmeftFR v4.0 - class 216 (psi^2 X H D^2) operator: leBHD2n2 *)

(* Q_leBHD2^(2) = (lbar_p D^rho e_r) (D^nu H) Btilde_{rho nu} + h.c. *)
LQleBHD2n2 := Module[{sp,ii,nu,si,al,be,ff1,ff2,aux,tmp},

tmp = ExpandIndices[ LL8bar[sp,ii,ff1].DC[lR8[sp,ff2],si]
  DC[Phi8[ii],nu]
  Eps[si,nu,al,be]/2 HC[FS[B8,al,be]],
  FlavorExpand->{SU2D8} ];

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "leBHD2n2"][ff1,ff2] tmp,
  FlavorExpand->{SU2W8} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];
