aux = ExpandIndices[ ToExpression[SMEFT$WB <> "quG2phin5"][ff1,ff2]
  f[aa,bb,cc] QLbar[sp1,ii,ff1,mm].uR[sp2,ff2,nn] Sigma[mu,nu,sp1,sp2]
  T[aa,mm,nn] Eps[ii,kk] HC[Phi8[kk]] FS[Gl,mu,ro,bb] FS[Gl,nu,ro,cc],
  FlavorExpand->{SU2D} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];


(* Q_quGWphi^(1) = (qbar_p T^A u_r) tau^I Htilde G^A_{mu nu} W^{I mu nu} + h.c. *)
