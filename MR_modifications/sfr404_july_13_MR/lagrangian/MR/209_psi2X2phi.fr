  QLbar[sp,ii,ff1,cc].uR[sp,ff2,cc] Eps[ii,kk] HC[Phi8[kk]]
  Eps[mu,nu,al,be]/2 HC[FS[Gl,al,be,aa]] FS[Gl,mu,nu,aa],
  FlavorExpand->{SU2D} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];


(* Q_quG2phi^(3) = d^{ABC} (qbar_p T^A u_r) Htilde G^B_{mu nu} G^{C mu nu} + h.c. *)
LQquG2phin3 := Module[{sp,ii,kk,mm,nn,aa,bb,cc,mu,nu,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "quG2phin3"][ff1,ff2]
  dSUN[aa,bb,cc] QLbar[sp,ii,ff1,mm].uR[sp,ff2,nn] T[aa,mm,nn]
  Eps[ii,kk] HC[Phi8[kk]] FS[Gl,mu,nu,bb] FS[Gl,mu,nu,cc],
  FlavorExpand->{SU2D} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];


(* Q_quG2phi^(4) = d^{ABC} (qbar_p T^A u_r) Htilde Gtilde^B_{mu nu} G^{C mu nu} + h.c. *)
LQquG2phin4 := Module[{sp,ii,kk,mm,nn,aa,bb,cc,mu,nu,al,be,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "quG2phin4"][ff1,ff2]
  dSUN[aa,bb,cc] QLbar[sp,ii,ff1,mm].uR[sp,ff2,nn] T[aa,mm,nn]
  Eps[ii,kk] HC[Phi8[kk]] Eps[mu,nu,al,be]/2 HC[FS[Gl,al,be,bb]]
  FS[Gl,mu,nu,cc], FlavorExpand->{SU2D} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];


(* Q_quG2phi^(5) = f^{ABC} (qbar_p sigma^{mu nu} T^A u_r) Htilde G^B_{mu ro} G^{C ro}_nu + h.c. *)
