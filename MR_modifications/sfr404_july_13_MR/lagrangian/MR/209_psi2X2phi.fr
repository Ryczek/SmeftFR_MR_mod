(* SmeftFR v4.0 package *)
(* dim-8 operators from 2005.00059 - psi^2X^2H class*)

(* Operators implemented AD, 08/06/2026: leG2phin1 *)

(* Class 9 (psi^2 X^2 H + h.c.) FULL TABLE of 2005.00059 completed, MR 16/06/2026:

   First column (2005.00059, page 1 of class-9 table):
   leptonic:  leG2phin1, leG2phin2, leW2phin1, leW2phin2, leW2phin3
   up-quark:  quG2phin1..quG2phin5, quGWphin1..quGWphin3,
              quGBphin1..quGBphin3, quW2phin1..quW2phin3,
              quWBphin1..quWBphin3, quB2phin1, quB2phin2

   Second column (2005.00059, continuation of class-9 table):
   leptonic:    leWBphin1..leWBphin3, leB2phin1, leB2phin2
   down-quark:  qdG2phin1..qdG2phin5, qdGWphin1..qdGWphin3,
                qdGBphin1..qdGBphin3, qdW2phin1..qdW2phin3,
                qdWBphin1..qdWBphin3, qdB2phin1, qdB2phin2

   Conventions (cf. dim-6 files 05_psi2Xphi.fr, 03_psi2phi3.fr and
   bosonic dim-8 files 04_X2phi2.fr, 205_X3phi2.fr):
   - lepton scalar bilinear (lbar_p e_r) H : LLbar[sp,ii,ff1].lR[sp,ff2] Phi8[ii]
   - up-quark scalar bilinear (qbar_p u_r) Htilde : Eps[ii,kk] HC[Phi8[kk]]
   - down-quark scalar bilinear (qbar_p d_r) H : QLbar[sp,ii,ff1,cc].dR[sp,ff2,cc] Phi8[ii]
     (NB: column 2 lepton and down-quark operators use the plain Higgs H,
      contracting its doublet index with the left-doublet, exactly like
      the dim-6 dphi/dG/dW operators; only the column-1 up-quark operators
      use the conjugate Higgs Htilde = Eps[ii,kk] HC[Phi8[kk]].)
   - tau^I doublet structure : 2 Ta[ll,ii,jj]
   - dual field strength Xtilde_{mu nu} = 1/2 eps_{mu nu al be} X^{al be} :
       Eps[mu,nu,al,be]/2 HC[FS[X,al,be,..]]
   - SU(3) symmetric / antisymmetric constants : dSUN[A,B,C], f[A,B,C]
   - `FlavorExpand`: operators with only `G`/`B` use `{SU2D}`; any operator
     with `W` and/or `tau^I` uses two-step expansion: `{SU2D}` first, then
     `{SU2W}` (cf. `LQl4Wn1` in `219_psi4X.fr`). Single-step
     `FlavorExpand->{SU2W,SU2D}` can hit `$RecursionLimit`.
   - eps^{IJK} (SU(2)) : Eps[I,J,K] resolved in the `{SU2W}` step.            *)


(* ============================ leptonic ============================ *)

(* Q_leG2phi^(1) = (lbar_p e_r) H G^A_{mu nu} G^{A mu nu} + h.c. *)
LQleG2phin1 := Module[{sp,ii,mu,nu,aa,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "leG2phin1"][ff1,ff2]
  LLbar[sp,ii,ff1].lR[sp,ff2] Phi8[ii] FS[Gl,mu,nu,aa]
  FS[Gl,mu,nu,aa], FlavorExpand->{SU2D} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];


(* Q_leG2phi^(2) = (lbar_p e_r) H Gtilde^A_{mu nu} G^{A mu nu} + h.c. *)
LQleG2phin2 := Module[{sp,ii,mu,nu,al,be,aa,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "leG2phin2"][ff1,ff2]
  LLbar[sp,ii,ff1].lR[sp,ff2] Phi8[ii] Eps[mu,nu,al,be]/2
  HC[FS[Gl,al,be,aa]] FS[Gl,mu,nu,aa], FlavorExpand->{SU2D} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];


(* Q_leW2phi^(1) = (lbar_p e_r) H W^I_{mu nu} W^{I mu nu} + h.c. *)
LQleW2phin1 := Module[{sp,ii,mu,nu,ll,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "leW2phin1"][ff1,ff2]
  LLbar[sp,ii,ff1].lR[sp,ff2] Phi8[ii] FS[Wi,mu,nu,ll]
  FS[Wi,mu,nu,ll], FlavorExpand -> {SU2D} ];

aux = ExpandIndices[aux, FlavorExpand -> {SU2W} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];


(* Q_leW2phi^(2) = (lbar_p e_r) H Wtilde^I_{mu nu} W^{I mu nu} + h.c. *)
LQleW2phin2 := Module[{sp,ii,mu,nu,al,be,ll,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "leW2phin2"][ff1,ff2]
  LLbar[sp,ii,ff1].lR[sp,ff2] Phi8[ii] Eps[mu,nu,al,be]/2
  HC[FS[Wi,al,be,ll]] FS[Wi,mu,nu,ll], FlavorExpand -> {SU2D} ];

aux = ExpandIndices[aux, FlavorExpand -> {SU2W} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];


(* Q_leW2phi^(3) = eps^{IJK} (lbar_p sigma^{mu nu} e_r) tau^I H W^J_{mu ro} W^{K ro}_nu + h.c. *)
LQleW2phin3 := Module[{sp1,sp2,ii,jj,aa,bb,cc,mu,nu,ro,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "leW2phin3"][ff1,ff2]
  Eps[aa,bb,cc] LLbar[sp1,ii,ff1].lR[sp2,ff2] Sigma[mu,nu,sp1,sp2]
  2 Ta[aa,ii,jj] Phi8[jj] FS[Wi,mu,ro,bb] FS[Wi,nu,ro,cc],
  FlavorExpand -> {SU2D} ];

aux = ExpandIndices[aux, FlavorExpand -> {SU2W} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];


(* ============================== quark ============================= *)

(* Q_quG2phi^(1) = (qbar_p u_r) Htilde G^A_{mu nu} G^{A mu nu} + h.c. *)
LQquG2phin1 := Module[{sp,ii,kk,cc,mu,nu,aa,ff1,ff2,aux},

aux = ExpandIndices[ ToExpression[SMEFT$WB <> "quG2phin1"][ff1,ff2]
  QLbar[sp,ii,ff1,cc].uR[sp,ff2,cc] Eps[ii,kk] HC[Phi8[kk]]
  FS[Gl,mu,nu,aa] FS[Gl,mu,nu,aa], FlavorExpand->{SU2D} ];

(aux + HC[aux]) /. SMEFTGaugeRules
];


(* Q_quG2phi^(2) = (qbar_p u_r) Htilde Gtilde^A_{mu nu} G^{A mu nu} + h.c. *)
