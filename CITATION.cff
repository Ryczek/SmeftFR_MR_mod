    given-names: "A."
  - family-names: "Rosiek"
    given-names: "J."
  - family-names: "Ryczkowski"
    given-names: "M."
  - family-names: "Suxho"
    given-names: "K."
  - family-names: "Trifyllis"
    given-names: "L."
version: "3.0"
license: "GPL-3.0-or-later"
repository-code: "https://github.com/<ORG_OR_USER>/SmeftFR"
url: "https://github.com/<ORG_OR_USER>/SmeftFR"
keywords:
  - SMEFT
  - Standard Model Effective Field Theory
  - Feynman rules
  - Mathematica
  - FeynRules
  - dimension-6
  - dimension-8
  - UFO
  - FeynArts

